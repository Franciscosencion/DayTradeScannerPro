<Page x:Class="TradeScanner.UI.Views.Charts.ChartsView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
      Title="Charts">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Symbol Bar + Stats -->
        <Border Grid.Row="0" Background="{StaticResource SurfaceBrush}" Padding="16,10">
            <StackPanel Orientation="Horizontal">
                <TextBox Text="{Binding Symbol, UpdateSourceTrigger=PropertyChanged}"
                         Width="100" Margin="0,0,8,0" Padding="8,6"
                         Style="{StaticResource InputStyle}"
                         Tag="Symbol">
                    <TextBox.InputBindings>
                        <KeyBinding Key="Return" Command="{Binding LoadChartCommand}"/>
                    </TextBox.InputBindings>
                </TextBox>
                <Button Content="Load Chart"
                        Command="{Binding LoadChartCommand}"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Margin="0,0,24,0"/>

                <!-- Live stats from provider -->
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="{Binding LastPrice}" FontSize="20" FontWeight="Bold"
                               Foreground="{StaticResource AccentBrush}" Margin="0,0,12,0"/>
                    <TextBlock Text="{Binding ChangeText}" FontSize="14"
                               Foreground="{Binding IsPositive, Converter={StaticResource BoolToGreenRedConverter}}"
                               VerticalAlignment="Center" Margin="0,0,16,0"/>
                    <TextBlock Text="Vol: " Foreground="{StaticResource MutedTextBrush}" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding VolumeText}" Foreground="{StaticResource TextBrush}"
                               VerticalAlignment="Center" Margin="4,0,16,0"/>
                    <TextBlock Text="Range: " Foreground="{StaticResource MutedTextBrush}" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding DayRange}" Foreground="{StaticResource TextBrush}"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- TradingView Advanced Chart (WebView2) -->
        <Grid Grid.Row="1">
            <wv2:WebView2 x:Name="ChartWebView" />
            <!-- Shown while WebView2 is initialising or chart is loading -->
            <Border Background="{StaticResource BackgroundBrush}"
                    Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibilityConverter}}">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <ProgressBar IsIndeterminate="True" Width="160" Height="4" Margin="0,0,0,10"/>
                    <TextBlock Text="{Binding StatusMessage}" Foreground="{StaticResource MutedTextBrush}" FontSize="12"
                               HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Status Bar -->
        <Border Grid.Row="2" Background="{StaticResource StatusBarBrush}" Padding="12,4">
            <TextBlock Text="{Binding StatusMessage}" Foreground="{StaticResource MutedTextBrush}" HorizontalAlignment="Left"/>
        </Border>
    </Grid>
</Page>
