<Page x:Class="TradeScanner.UI.Views.Providers.ProvidersView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:enums="clr-namespace:TradeScanner.Core.Domain.Enums;assembly=TradeScanner.Core"
      Title="Data Providers">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Configure API Keys" Style="{StaticResource SectionHeaderStyle}" Margin="0,0,0,4"/>
        <TextBlock Grid.Row="1" Text="Keys are stored encrypted (DPAPI). The field clears after saving — a key icon indicates a saved key."
                   Foreground="{StaticResource MutedTextBrush}" FontSize="11" Margin="0,0,0,16"/>

        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
            <StackPanel>

                <ItemsControl ItemsSource="{Binding Providers}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="{StaticResource SurfaceBrush}" CornerRadius="8" Margin="0,0,0,10" Padding="16,12">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="200"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="100"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Provider info -->
                                    <StackPanel Grid.Column="0">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding DisplayName}" FontWeight="Bold"
                                                       Foreground="{StaticResource TextBrush}"/>
                                            <TextBlock Text=" 🔑" FontSize="11" VerticalAlignment="Center"
                                                       Visibility="{Binding HasSavedKey, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                        </StackPanel>
                                        <TextBlock Text="{Binding ProviderType}" Foreground="{StaticResource MutedTextBrush}" FontSize="11"/>
                                        <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                            <Ellipse Width="8" Height="8" Margin="0,0,4,0"
                                                     Fill="{Binding IsAvailable, Converter={StaticResource BoolToGreenRedConverter}}"/>
                                            <TextBlock Text="{Binding IsAvailable, Converter={StaticResource BoolToAvailableConverter}}"
                                                       FontSize="11" Foreground="{StaticResource MutedTextBrush}"/>
                                        </StackPanel>
                                    </StackPanel>

                                    <!-- API key / cookie input — placeholder differs for Yahoo Finance -->
                                    <TextBox Grid.Column="1" Margin="0,0,8,0"
                                             Text="{Binding ApiKey, UpdateSourceTrigger=PropertyChanged}">
                                        <TextBox.Style>
                                            <Style TargetType="TextBox" BasedOn="{StaticResource InputStyle}">
                                                <Setter Property="Tag" Value="Paste API key here, then Save or Validate"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding ProviderType}"
                                                                 Value="{x:Static enums:MarketDataProvider.YahooFinance}">
                                                        <Setter Property="Tag" Value="Paste browser Cookie header here, then Save (see instructions below)"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBox.Style>
                                    </TextBox>

                                    <!-- Save -->
                                    <Button Grid.Column="2" Content="Save" Margin="0,0,6,0"
                                            Command="{Binding DataContext.SaveApiKeyCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                            CommandParameter="{Binding}"
                                            Style="{StaticResource PrimaryButtonStyle}"/>

                                    <!-- Validate -->
                                    <Button Grid.Column="3" Content="Validate" Margin="0,0,6,0"
                                            Command="{Binding DataContext.ValidateProviderCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                            CommandParameter="{Binding}"
                                            Style="{StaticResource SecondaryButtonStyle}"/>

                                    <!-- Clear -->
                                    <Button Grid.Column="4" Content="Clear" Margin="0,0,8,0"
                                            Command="{Binding DataContext.ClearApiKeyCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                            CommandParameter="{Binding}"
                                            Style="{StaticResource SecondaryButtonStyle}"/>

                                    <!-- Status -->
                                    <TextBlock Grid.Column="5" Text="{Binding ValidationStatus}"
                                               VerticalAlignment="Center"
                                               Foreground="{Binding ValidationStatus, Converter={StaticResource ValidationToColorConverter}}"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Yahoo Finance cookie instructions -->
                <Border Background="{StaticResource SurfaceBrush}" CornerRadius="8" Margin="0,4,0,16" Padding="16,14">
                    <StackPanel>
                        <TextBlock Text="Yahoo Finance — Session Cookie Instructions"
                                   FontWeight="Bold" Foreground="{StaticResource TextBrush}" Margin="0,0,0,8"/>
                        <TextBlock TextWrapping="Wrap" FontSize="11" Foreground="{StaticResource MutedTextBrush}"
                                   Text="Yahoo Finance requires browser session cookies for programmatic access. The app attempts automatic login on startup. If Yahoo shows as unavailable (red dot), follow these steps to supply cookies manually:"/>
                        <TextBlock TextWrapping="Wrap" FontSize="11" Foreground="{StaticResource MutedTextBrush}" Margin="0,6,0,2"
                                   Text="1. Open Chrome or Edge and navigate to finance.yahoo.com — allow the page to fully load."/>
                        <TextBlock TextWrapping="Wrap" FontSize="11" Foreground="{StaticResource MutedTextBrush}" Margin="0,2,0,2"
                                   Text="2. Press F12 to open DevTools, click the Network tab, then reload the page (F5)."/>
                        <TextBlock TextWrapping="Wrap" FontSize="11" Foreground="{StaticResource MutedTextBrush}" Margin="0,2,0,2"
                                   Text="3. Click any request in the list to finance.yahoo.com or yahoo.com, then in the Headers panel find the Cookie request header."/>
                        <TextBlock TextWrapping="Wrap" FontSize="11" Foreground="{StaticResource MutedTextBrush}" Margin="0,2,0,2"
                                   Text="4. Right-click the Cookie value and choose Copy value (or select all and copy). Paste it into the Yahoo Finance field above and click Save."/>
                        <TextBlock TextWrapping="Wrap" FontSize="11" Foreground="{StaticResource MutedTextBrush}" Margin="0,6,0,0"
                                   Text="Tip: Session cookies expire after approximately 30 days. Click Validate to test whether the current cookies are still working. Repeat these steps if Yahoo Finance stops working."/>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
