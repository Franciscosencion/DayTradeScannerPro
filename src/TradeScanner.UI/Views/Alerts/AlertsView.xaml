<Page x:Class="TradeScanner.UI.Views.Alerts.AlertsView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Alerts">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Add Alert Panel -->
        <Border Grid.Row="0" Background="{StaticResource SurfaceBrush}" Padding="16,10">
            <WrapPanel Orientation="Horizontal">
                <TextBox Text="{Binding NewSymbol, UpdateSourceTrigger=PropertyChanged}"
                         Width="100" Margin="0,0,8,0" Tag="Symbol"
                         Style="{StaticResource InputStyle}"/>
                <ComboBox ItemsSource="{Binding AlertTypes}"
                          SelectedItem="{Binding NewAlertType}"
                          Width="140" Margin="0,0,8,0"/>
                <TextBox Text="{Binding NewThreshold, UpdateSourceTrigger=PropertyChanged}"
                         Width="100" Margin="0,0,8,0" Tag="Threshold"
                         Style="{StaticResource InputStyle}"/>
                <Button Content="Add Alert"
                        Command="{Binding AddAlertCommand}"
                        Style="{StaticResource PrimaryButtonStyle}"/>
            </WrapPanel>
        </Border>

        <!-- Alert List -->
        <DataGrid Grid.Row="1"
                  ItemsSource="{Binding Alerts}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  Background="Transparent">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Symbol" Binding="{Binding Symbol}" Width="90"/>
                <DataGridTextColumn Header="Type" Binding="{Binding AlertType}" Width="130"/>
                <DataGridTextColumn Header="Threshold" Binding="{Binding Threshold, StringFormat='{}{0:F2}'}" Width="90"/>
                <DataGridCheckBoxColumn Header="Enabled" Binding="{Binding IsEnabled}" Width="70"/>
                <DataGridTextColumn Header="Triggered" Binding="{Binding TriggerCount}" Width="80"/>
                <DataGridTextColumn Header="Last At"
                                    Binding="{Binding LastTriggeredAt, StringFormat='HH:mm:ss'}" Width="90"/>
                <DataGridTemplateColumn Header="Actions" Width="*">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <Button Content="Toggle"
                                        Command="{Binding DataContext.ToggleAlertCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                        CommandParameter="{Binding}"
                                        Style="{StaticResource SecondaryButtonStyle}" Padding="8,3" Margin="0,0,4,0"/>
                                <Button Content="Delete"
                                        Command="{Binding DataContext.DeleteAlertCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                        CommandParameter="{Binding}"
                                        Style="{StaticResource DangerButtonStyle}" Padding="8,3"/>
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Page>
