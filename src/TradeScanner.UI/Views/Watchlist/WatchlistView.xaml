<Page x:Class="TradeScanner.UI.Views.Watchlist.WatchlistView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Watchlist">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Add Symbol Bar -->
        <Border Grid.Row="0" Background="{StaticResource SurfaceBrush}" Padding="16,10">
            <StackPanel Orientation="Horizontal">
                <TextBox Text="{Binding NewSymbol, UpdateSourceTrigger=PropertyChanged}"
                         Width="120" Margin="0,0,8,0" Padding="8,6"
                         Style="{StaticResource InputStyle}"
                         Tag="Symbol (e.g. AAPL)">
                    <TextBox.InputBindings>
                        <KeyBinding Key="Return" Command="{Binding AddSymbolCommand}"/>
                    </TextBox.InputBindings>
                </TextBox>
                <Button Content="Add to Watchlist"
                        Command="{Binding AddSymbolCommand}"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Margin="0,0,8,0"/>
                <Button Content="Refresh Quotes"
                        Command="{Binding RefreshQuotesCommand}"
                        Style="{StaticResource SecondaryButtonStyle}"/>
            </StackPanel>
        </Border>

        <!-- Watchlist Grid -->
        <DataGrid Grid.Row="1"
                  ItemsSource="{Binding QuoteRows}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  GridLinesVisibility="Horizontal"
                  HeadersVisibility="Column"
                  Background="Transparent"
                  RowBackground="Transparent"
                  AlternatingRowBackground="{StaticResource AlternateBrush}">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Symbol" Binding="{Binding Symbol}" Width="100"
                                    ElementStyle="{StaticResource BoldAccentCell}"/>
                <DataGridTextColumn Header="Price" Binding="{Binding Price, StringFormat='${0:F2}'}" Width="90"/>
                <DataGridTemplateColumn Header="Change%" Width="90">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding ChangePercent, StringFormat='{}{0:+0.00;-0.00}%'}"
                                       Foreground="{Binding IsPositive, Converter={StaticResource BoolToGreenRedConverter}}"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTextColumn Header="Volume" Binding="{Binding Volume, StringFormat='{}{0:N0}'}" Width="110"/>
                <DataGridTemplateColumn Header="Actions" Width="*">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Button Content="Remove"
                                    Command="{Binding DataContext.RemoveSymbolCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                    CommandParameter="{Binding Symbol}"
                                    Style="{StaticResource DangerButtonStyle}"
                                    Padding="8,3" Margin="0,1"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Page>
