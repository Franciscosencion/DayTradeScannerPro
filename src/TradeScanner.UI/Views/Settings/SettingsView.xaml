<Page x:Class="TradeScanner.UI.Views.Settings.SettingsView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Settings">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="24" MaxWidth="600">

            <TextBlock Text="Scanner Settings" Style="{StaticResource SectionHeaderStyle}" Margin="0,0,0,16"/>

            <!-- Scan Frequency -->
            <Grid Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="200"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Scan Frequency" Style="{StaticResource LabelStyle}" VerticalAlignment="Center"/>
                <ComboBox Grid.Column="1" ItemsSource="{Binding ScanFrequencies}"
                          SelectedItem="{Binding Settings.ScanFrequency}"/>
            </Grid>

            <!-- Filters -->
            <TextBlock Text="Filter Criteria" Style="{StaticResource SectionHeaderStyle}" Margin="0,16,0,12"/>

            <Grid Margin="0,0,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="200"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Min Price ($)" Style="{StaticResource LabelStyle}" VerticalAlignment="Center"/>
                <TextBox Grid.Column="1" Text="{Binding Settings.MinPrice, StringFormat='F2'}" Style="{StaticResource InputStyle}"/>
            </Grid>

            <Grid Margin="0,0,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="200"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Max Price ($)" Style="{StaticResource LabelStyle}" VerticalAlignment="Center"/>
                <TextBox Grid.Column="1" Text="{Binding Settings.MaxPrice, StringFormat='F2'}" Style="{StaticResource InputStyle}"/>
            </Grid>

            <Grid Margin="0,0,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="200"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Min Volume" Style="{StaticResource LabelStyle}" VerticalAlignment="Center"/>
                <TextBox Grid.Column="1" Text="{Binding Settings.MinVolume}" Style="{StaticResource InputStyle}"/>
            </Grid>

            <Grid Margin="0,0,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="200"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Min Change %" Style="{StaticResource LabelStyle}" VerticalAlignment="Center"/>
                <TextBox Grid.Column="1" Text="{Binding Settings.MinChangePercent, StringFormat='F1'}" Style="{StaticResource InputStyle}"/>
            </Grid>

            <Grid Margin="0,0,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="200"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Min Trade Score" Style="{StaticResource LabelStyle}" VerticalAlignment="Center"/>
                <Slider Grid.Column="1" Minimum="0" Maximum="100" IsSnapToTickEnabled="True" TickFrequency="5"
                        Value="{Binding Settings.MinTradeScore}"/>
            </Grid>

            <!-- Score Weights -->
            <TextBlock Text="Score Weights" Style="{StaticResource SectionHeaderStyle}" Margin="0,16,0,12"/>

            <Grid Margin="0,0,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="200"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="50"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Momentum" Style="{StaticResource LabelStyle}" VerticalAlignment="Center"/>
                <Slider Grid.Column="1" Minimum="0" Maximum="1" TickFrequency="0.05" IsSnapToTickEnabled="True"
                        Value="{Binding Settings.MomentumWeight}"/>
                <TextBlock Grid.Column="2" Text="{Binding Settings.MomentumWeight, StringFormat='{}{0:P0}'}"
                           Style="{StaticResource LabelStyle}" VerticalAlignment="Center" HorizontalAlignment="Right"/>
            </Grid>

            <Grid Margin="0,0,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="200"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="50"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Volume" Style="{StaticResource LabelStyle}" VerticalAlignment="Center"/>
                <Slider Grid.Column="1" Minimum="0" Maximum="1" TickFrequency="0.05" IsSnapToTickEnabled="True"
                        Value="{Binding Settings.VolumeWeight}"/>
                <TextBlock Grid.Column="2" Text="{Binding Settings.VolumeWeight, StringFormat='{}{0:P0}'}"
                           Style="{StaticResource LabelStyle}" VerticalAlignment="Center" HorizontalAlignment="Right"/>
            </Grid>

            <!-- Alerts -->
            <TextBlock Text="Notifications" Style="{StaticResource SectionHeaderStyle}" Margin="0,16,0,12"/>

            <Grid Margin="0,0,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="200"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Sound Alerts" Style="{StaticResource LabelStyle}" VerticalAlignment="Center"/>
                <CheckBox Grid.Column="1" IsChecked="{Binding Settings.EnableSoundAlerts}" VerticalAlignment="Center"/>
            </Grid>

            <Grid Margin="0,0,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="200"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Popup Alerts" Style="{StaticResource LabelStyle}" VerticalAlignment="Center"/>
                <CheckBox Grid.Column="1" IsChecked="{Binding Settings.EnablePopupAlerts}" VerticalAlignment="Center"/>
            </Grid>

            <!-- Appearance -->
            <TextBlock Text="Appearance" Style="{StaticResource SectionHeaderStyle}" Margin="0,16,0,12"/>

            <Grid Margin="0,0,0,24">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="200"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Theme" Style="{StaticResource LabelStyle}" VerticalAlignment="Center"/>
                <ComboBox Grid.Column="1" ItemsSource="{Binding Themes}" SelectedItem="{Binding Settings.Theme}"/>
            </Grid>

            <!-- Save -->
            <StackPanel Orientation="Horizontal">
                <Button Content="Save Settings" Command="{Binding SaveCommand}" Style="{StaticResource PrimaryButtonStyle}" Margin="0,0,8,0"/>
                <Button Content="Reset Defaults" Command="{Binding ResetDefaultsCommand}" Style="{StaticResource SecondaryButtonStyle}"/>
            </StackPanel>

            <TextBlock Text="{Binding SaveStatus}" Margin="0,8,0,0"
                       Foreground="{StaticResource AccentBrush}" FontStyle="Italic"/>

        </StackPanel>
    </ScrollViewer>
</Page>
