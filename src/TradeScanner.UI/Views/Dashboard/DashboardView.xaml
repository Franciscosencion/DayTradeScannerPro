<Page x:Class="TradeScanner.UI.Views.Dashboard.DashboardView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      mc:Ignorable="d"
      Title="Dashboard">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <Border Grid.Row="0" Background="{StaticResource SurfaceBrush}" Padding="16,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Scanner controls -->
                <Button Grid.Column="0" Margin="0,0,8,0"
                        Command="{Binding ToggleScanCommand}"
                        Style="{StaticResource PrimaryButtonStyle}">
                    <Button.Content>
                        <TextBlock Text="{Binding IsScanning, Converter={StaticResource BoolToScanLabelConverter}}"/>
                    </Button.Content>
                </Button>

                <Button Grid.Column="1" Content="Scan Once"
                        Command="{Binding RunScanOnceCommand}"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Margin="0,0,8,0"/>

                <Button Grid.Column="2" Content="Export CSV"
                        Command="{Binding ExportCommand}"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Margin="0,0,8,0"/>

                <!-- Relaxed Mode toggle: bypasses MinChange%, MinVolume, MinScore filters -->
                <Button Grid.Column="3" Content="Relaxed Mode"
                        Command="{Binding ToggleRelaxedModeCommand}"
                        Margin="0,0,16,0"
                        VerticalAlignment="Center">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource SecondaryButtonStyle}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding RelaxedScanMode}" Value="True">
                                    <Setter Property="BorderBrush" Value="{StaticResource GreenBrush}"/>
                                    <Setter Property="Foreground" Value="{StaticResource GreenBrush}"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>

                <!-- Separator -->
                <Rectangle Grid.Column="4" Width="1" Fill="{StaticResource DividerBrush}" Margin="0,4,16,4"/>

                <!-- Streaming controls -->
                <ComboBox Grid.Column="5"
                          ItemsSource="{Binding StreamingProviders}"
                          SelectedItem="{Binding SelectedStreamingProvider}"
                          Width="90" Margin="0,0,6,0" Padding="6,4"
                          VerticalAlignment="Center"/>

                <TextBox Grid.Column="6"
                         Text="{Binding StreamingApiKey, UpdateSourceTrigger=PropertyChanged}"
                         Width="160" Margin="0,0,6,0" Padding="6,4"
                         Tag="API Key"
                         Style="{StaticResource InputStyle}"
                         VerticalAlignment="Center"/>

                <Button Grid.Column="7"
                        Command="{Binding ToggleStreamingCommand}"
                        Style="{StaticResource SecondaryButtonStyle}"
                        VerticalAlignment="Center">
                    <Button.Content>
                        <TextBlock Text="{Binding IsStreaming, Converter={StaticResource BoolToStreamLabelConverter}}"/>
                    </Button.Content>
                </Button>

                <!-- Stats -->
                <StackPanel Grid.Column="9" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Results: " Foreground="{StaticResource MutedTextBrush}" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding ResultCount}" Foreground="{StaticResource AccentBrush}"
                               FontWeight="Bold" VerticalAlignment="Center" Margin="4,0,16,0"/>
                    <TextBlock Text="Last: " Foreground="{StaticResource MutedTextBrush}" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding LastScanTime, StringFormat='HH:mm:ss'}"
                               Foreground="{StaticResource TextBrush}" VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Results DataGrid — resizable columns, native sort on header click -->
        <DataGrid Grid.Row="1"
                  ItemsSource="{Binding SortedResults}"
                  SelectedItem="{Binding SelectedResult}"
                  AutoGenerateColumns="False"
                  CanUserResizeColumns="True"
                  CanUserSortColumns="True"
                  CanUserReorderColumns="False"
                  IsReadOnly="True"
                  SelectionMode="Single"
                  SelectionUnit="FullRow"
                  HeadersVisibility="Column"
                  VirtualizingPanel.IsVirtualizing="True"
                  VirtualizingPanel.VirtualizationMode="Recycling">
            <DataGrid.Columns>

                <!-- Symbol — click to open chart -->
                <DataGridTemplateColumn Header="SYMBOL" Width="110" MinWidth="70" SortMemberPath="Symbol">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Button Content="{Binding Symbol}"
                                    Command="{Binding DataContext.OpenChartCommand,
                                              RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                    CommandParameter="{Binding Symbol}"
                                    Style="{StaticResource SymbolLinkButtonStyle}"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <!-- Score — coloured badge -->
                <DataGridTemplateColumn Header="SCORE" Width="80" MinWidth="60" SortMemberPath="TradeScore">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Border CornerRadius="4" Padding="6,2" HorizontalAlignment="Left"
                                    Background="{Binding TradeScore, Converter={StaticResource ScoreToColorConverter}}">
                                <TextBlock Text="{Binding TradeScore}" Foreground="White" FontWeight="Bold"
                                           HorizontalAlignment="Center"/>
                            </Border>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <!-- Price -->
                <DataGridTextColumn Header="PRICE" Width="90" MinWidth="70"
                                    Binding="{Binding Price, StringFormat='${0:F2}'}"
                                    SortMemberPath="Price">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
                            <Setter Property="VerticalAlignment" Value="Center"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <!-- Change% — coloured -->
                <DataGridTemplateColumn Header="CHANGE%" Width="95" MinWidth="70" SortMemberPath="ChangePercent">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding ChangePercent, StringFormat='{}{0:+0.00;-0.00}%'}"
                                       Foreground="{Binding ChangePercent, Converter={StaticResource ChangeToColorConverter}}"
                                       VerticalAlignment="Center"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <!-- Volume -->
                <DataGridTextColumn Header="VOLUME" Width="110" MinWidth="80"
                                    Binding="{Binding Volume, StringFormat='{}{0:N0}'}"
                                    SortMemberPath="Volume">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
                            <Setter Property="VerticalAlignment" Value="Center"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <!-- Vol Ratio -->
                <DataGridTextColumn Header="VOL RATIO" Width="90" MinWidth="70"
                                    Binding="{Binding VolumeRatio, StringFormat='{}{0:F2}x'}"
                                    SortMemberPath="VolumeRatio">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="{StaticResource AccentBrush}"/>
                            <Setter Property="VerticalAlignment" Value="Center"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <!-- Momentum -->
                <DataGridTextColumn Header="MOMENTUM" Width="95" MinWidth="70"
                                    Binding="{Binding MomentumScore, StringFormat='{}{0:F0}'}"
                                    SortMemberPath="MomentumScore">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
                            <Setter Property="VerticalAlignment" Value="Center"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <!-- Technical -->
                <DataGridTextColumn Header="TECHNICAL" Width="95" MinWidth="70"
                                    Binding="{Binding TechnicalScore, StringFormat='{}{0:F0}'}"
                                    SortMemberPath="TechnicalScore">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
                            <Setter Property="VerticalAlignment" Value="Center"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <!-- Signals — fills remaining space -->
                <DataGridTextColumn Header="SIGNALS" Width="*" MinWidth="100"
                                    Binding="{Binding SignalsSerialized}"
                                    SortMemberPath="SignalsSerialized">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="{StaticResource MutedTextBrush}"/>
                            <Setter Property="VerticalAlignment" Value="Center"/>
                            <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

            </DataGrid.Columns>
        </DataGrid>

        <!-- Status Bar -->
        <Border Grid.Row="2" Background="{StaticResource StatusBarBrush}" Padding="12,4">
            <Grid>
                <TextBlock Text="{Binding ScanStatus}" Foreground="{StaticResource MutedTextBrush}" HorizontalAlignment="Left"/>
                <ProgressBar IsIndeterminate="{Binding IsBusy}" Height="4" Width="120"
                             HorizontalAlignment="Right" Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibilityConverter}}"/>
            </Grid>
        </Border>
    </Grid>
</Page>
