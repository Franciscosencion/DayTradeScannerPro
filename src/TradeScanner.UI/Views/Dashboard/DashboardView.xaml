<Page x:Class="TradeScanner.UI.Views.Dashboard.DashboardView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      mc:Ignorable="d"
      Title="Dashboard">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <Border Grid.Row="0" Background="{StaticResource SurfaceBrush}" Padding="16,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Scanner controls -->
                <Button Grid.Column="0" Margin="0,0,8,0"
                        Command="{Binding ToggleScanCommand}"
                        Style="{StaticResource PrimaryButtonStyle}">
                    <Button.Content>
                        <TextBlock Text="{Binding IsScanning, Converter={StaticResource BoolToScanLabelConverter}}"/>
                    </Button.Content>
                </Button>

                <Button Grid.Column="1" Content="Scan Once"
                        Command="{Binding RunScanOnceCommand}"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Margin="0,0,8,0"/>

                <Button Grid.Column="2" Content="Export CSV"
                        Command="{Binding ExportCommand}"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Margin="0,0,16,0"/>

                <!-- Separator -->
                <Rectangle Grid.Column="3" Width="1" Fill="{StaticResource DividerBrush}" Margin="0,4,16,4"/>

                <!-- Streaming controls -->
                <ComboBox Grid.Column="4"
                          ItemsSource="{Binding StreamingProviders}"
                          SelectedItem="{Binding SelectedStreamingProvider}"
                          Width="90" Margin="0,0,6,0" Padding="6,4"
                          VerticalAlignment="Center"/>

                <TextBox Grid.Column="5"
                         Text="{Binding StreamingApiKey, UpdateSourceTrigger=PropertyChanged}"
                         Width="160" Margin="0,0,6,0" Padding="6,4"
                         Tag="API Key"
                         Style="{StaticResource InputStyle}"
                         VerticalAlignment="Center"/>

                <Button Grid.Column="6"
                        Command="{Binding ToggleStreamingCommand}"
                        Style="{StaticResource SecondaryButtonStyle}"
                        VerticalAlignment="Center">
                    <Button.Content>
                        <TextBlock Text="{Binding IsStreaming, Converter={StaticResource BoolToStreamLabelConverter}}"/>
                    </Button.Content>
                </Button>

                <!-- Stats -->
                <StackPanel Grid.Column="8" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Results: " Foreground="{StaticResource MutedTextBrush}" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding ResultCount}" Foreground="{StaticResource AccentBrush}"
                               FontWeight="Bold" VerticalAlignment="Center" Margin="4,0,16,0"/>
                    <TextBlock Text="Last: " Foreground="{StaticResource MutedTextBrush}" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding LastScanTime, StringFormat='HH:mm:ss'}"
                               Foreground="{StaticResource TextBrush}" VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Column Headers -->
        <Border Grid.Row="1" Background="{StaticResource HeaderBrush}" Padding="12,6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="80"/>
                    <ColumnDefinition Width="70"/>
                    <ColumnDefinition Width="80"/>
                    <ColumnDefinition Width="80"/>
                    <ColumnDefinition Width="100"/>
                    <ColumnDefinition Width="80"/>
                    <ColumnDefinition Width="80"/>
                    <ColumnDefinition Width="80"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="SYMBOL" Style="{StaticResource HeaderLabelStyle}"/>
                <TextBlock Grid.Column="1" Text="SCORE" Style="{StaticResource HeaderLabelStyle}"/>
                <TextBlock Grid.Column="2" Text="PRICE" Style="{StaticResource HeaderLabelStyle}"/>
                <TextBlock Grid.Column="3" Text="CHANGE%" Style="{StaticResource HeaderLabelStyle}"/>
                <TextBlock Grid.Column="4" Text="VOLUME" Style="{StaticResource HeaderLabelStyle}"/>
                <TextBlock Grid.Column="5" Text="VOL RATIO" Style="{StaticResource HeaderLabelStyle}"/>
                <TextBlock Grid.Column="6" Text="MOMENTUM" Style="{StaticResource HeaderLabelStyle}"/>
                <TextBlock Grid.Column="7" Text="TECHNICAL" Style="{StaticResource HeaderLabelStyle}"/>
                <TextBlock Grid.Column="8" Text="SIGNALS" Style="{StaticResource HeaderLabelStyle}"/>
            </Grid>
        </Border>

        <!-- Results List -->
        <ListView Grid.Row="2"
                  ItemsSource="{Binding ScanResults}"
                  SelectedItem="{Binding SelectedResult}"
                  Background="Transparent"
                  BorderThickness="0"
                  VirtualizingPanel.IsVirtualizing="True"
                  VirtualizingPanel.VirtualizationMode="Recycling">
            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem">
                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                    <Setter Property="Padding" Value="12,6"/>
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="BorderThickness" Value="0,0,0,1"/>
                    <Setter Property="BorderBrush" Value="{StaticResource DividerBrush}"/>
                    <Style.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="{StaticResource HoverBrush}"/>
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Background" Value="{StaticResource SelectionBrush}"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </ListView.ItemContainerStyle>
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="70"/>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0" Text="{Binding Symbol}"
                                   Foreground="{StaticResource AccentBrush}" FontWeight="Bold"/>

                        <Border Grid.Column="1" CornerRadius="4" Padding="6,2"
                                Background="{Binding TradeScore, Converter={StaticResource ScoreToColorConverter}}">
                            <TextBlock Text="{Binding TradeScore}" Foreground="White" FontWeight="Bold"
                                       HorizontalAlignment="Center"/>
                        </Border>

                        <TextBlock Grid.Column="2" Text="{Binding Price, StringFormat='${0:F2}'}"
                                   Foreground="{StaticResource TextBrush}"/>

                        <TextBlock Grid.Column="3"
                                   Text="{Binding ChangePercent, StringFormat='{}{0:+0.00;-0.00}%'}"
                                   Foreground="{Binding ChangePercent, Converter={StaticResource ChangeToColorConverter}}"/>

                        <TextBlock Grid.Column="4" Text="{Binding Volume, StringFormat='{}{0:N0}'}"
                                   Foreground="{StaticResource TextBrush}"/>

                        <TextBlock Grid.Column="5" Text="{Binding VolumeRatio, StringFormat='{}{0:F2}x'}"
                                   Foreground="{StaticResource AccentBrush}"/>

                        <TextBlock Grid.Column="6" Text="{Binding MomentumScore, StringFormat='{}{0:F0}'}"
                                   Foreground="{StaticResource TextBrush}"/>

                        <TextBlock Grid.Column="7" Text="{Binding TechnicalScore, StringFormat='{}{0:F0}'}"
                                   Foreground="{StaticResource TextBrush}"/>

                        <TextBlock Grid.Column="8" Text="{Binding SignalsSerialized}"
                                   Foreground="{StaticResource MutedTextBrush}" TextTrimming="CharacterEllipsis"/>
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <!-- Status Bar -->
        <Border Grid.Row="3" Background="{StaticResource StatusBarBrush}" Padding="12,4">
            <Grid>
                <TextBlock Text="{Binding ScanStatus}" Foreground="{StaticResource MutedTextBrush}" HorizontalAlignment="Left"/>
                <ProgressBar IsIndeterminate="{Binding IsBusy}" Height="4" Width="120"
                             HorizontalAlignment="Right" Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibilityConverter}}"/>
            </Grid>
        </Border>
    </Grid>
</Page>
