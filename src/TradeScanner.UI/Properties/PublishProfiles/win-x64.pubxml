<?xml version="1.0" encoding="utf-8"?>
<!--
  Publish profile: self-contained, ReadyToRun, Windows x64
  Usage:
    dotnet publish TradeScanner.UI\TradeScanner.UI.csproj -p:PublishProfile=win-x64 -c Release
  Output lands in:  publish\win-x64\
  Then run Build-Msix.ps1 to wrap it into an MSIX package.
-->
<Project>
  <PropertyGroup>
    <Configuration>Release</Configuration>
    <Platform>Any CPU</Platform>
    <PublishDir>$(MSBuildThisFileDirectory)..\..\..\publish\win-x64\</PublishDir>
    <PublishProtocol>FileSystem</PublishProtocol>
    <TargetFramework>net10.0-windows</TargetFramework>
    <RuntimeIdentifier>win-x64</RuntimeIdentifier>
    <SelfContained>true</SelfContained>
    <PublishSingleFile>false</PublishSingleFile>
    <!-- ReadyToRun disabled: crossgen2 crashes when x86 SDK targets x64 -->
    <PublishReadyToRun>false</PublishReadyToRun>
    <EnableCompressionInSingleFile>false</EnableCompressionInSingleFile>
    <!-- Trim unused code to reduce package size (safe for WPF with explicit roots) -->
    <PublishTrimmed>false</PublishTrimmed>
  </PropertyGroup>
</Project>
