<?xml version="1.0" encoding="utf-8"?>
<Package
  xmlns="http://schemas.microsoft.com/appx/manifest/foundation/windows10"
  xmlns:uap="http://schemas.microsoft.com/appx/manifest/uap/windows10"
  xmlns:rescap="http://schemas.microsoft.com/appx/manifest/foundation/windows10/restrictedcapabilities"
  IgnorableNamespaces="uap rescap">

  <Identity
    Name="TradeScanner.DayTradePro"
    Publisher="CN=TradeScanner"
    Version="1.0.0.0"
    ProcessorArchitecture="x64"/>

  <Properties>
    <DisplayName>Day Trade Scanner Pro</DisplayName>
    <PublisherDisplayName>TradeScanner</PublisherDisplayName>
    <Logo>Assets\StoreLogo.png</Logo>
  </Properties>

  <Dependencies>
    <!-- Minimum: RS5 (1809, 10.0.17763). Tested up to Windows 11 24H2. -->
    <TargetDeviceFamily Name="Windows.Desktop"
                        MinVersion="10.0.17763.0"
                        MaxVersionTested="10.0.26100.0"/>
  </Dependencies>

  <Resources>
    <Resource Language="en-us"/>
  </Resources>

  <Applications>
    <Application Id="TradeScanner"
                 Executable="TradeScanner.exe"
                 EntryPoint="Windows.FullTrustApplication">
      <uap:VisualElements
          DisplayName="Day Trade Scanner Pro"
          Description="Professional day trading stock scanner with real-time alerts and scoring"
          BackgroundColor="transparent"
          Square150x150Logo="Assets\Square150x150Logo.png"
          Square44x44Logo="Assets\Square44x44Logo.png">
        <uap:DefaultTile Wide310x150Logo="Assets\Wide310x150Logo.png"
                         ShortName="TradeScanner"/>
        <uap:SplashScreen Image="Assets\SplashScreen.png"
                          BackgroundColor="#009688"/>
      </uap:VisualElements>
    </Application>
  </Applications>

  <Capabilities>
    <!-- Required for packaged desktop apps that run as full-trust Win32 processes -->
    <rescap:Capability Name="runFullTrust"/>
    <!-- Market data API calls over HTTPS -->
    <Capability Name="internetClient"/>
  </Capabilities>

</Package>
